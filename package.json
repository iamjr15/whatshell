{
  "name": "whatshell",
  "version": "0.1.2",
  "description": "Whatshell: a Rust WhatsApp Web CLI for coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamjr15/whatshell.git"
  },
  "bugs": {
    "url": "https://github.com/iamjr15/whatshell/issues"
  },
  "homepage": "https://github.com/iamjr15/whatshell#readme",
  "keywords": [
    "whatsapp",
    "whatsapp-web",
    "cli",
    "agent",
    "codex",
    "claude-code",
    "opencode",
    "rust"
  ],
  "bin": {
    "whatshell": "npm/bin/whatshell.js"
  },
  "scripts": {
    "postinstall": "node npm/install.js",
    "build": "cargo build --release",
    "test": "cargo test && node npm/test-install-skills.js",
    "test:skills": "node npm/test-install-skills.js"
  },
  "files": [
    "Cargo.toml",
    "Cargo.lock",
    "src",
    "npm/bin/whatshell.js",
    "npm/install.js",
    "npm/install-skills.js",
    "npm/test-install-skills.js",
    "skills",
    "README.md",
    "LICENSE",
    ".gitignore"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
